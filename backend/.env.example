# ══════════════════════════════════════════════════════════════════
# Fact-Checking RAG System — Environment Variables
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── LLM: Gemini (Primary — REQUIRED) ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── LLM: OpenRouter (Secondary Fallback) ──────────────────────────
OPENROUTER_API_KEY=
# You can provide a comma-separated list to let OpenRouter choose the best available free model
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free,google/gemini-2.0-pro-exp-02-05:free,mistralai/mistral-7b-instruct:free,deepseek/deepseek-chat:free

# ── LLM: Ollama (Tertiary Fallback) ───────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_ENABLED=false

# ── LLM: Shared ──────────────────────────────────────────────────
LLM_TIMEOUT=30

# ── Pinecone (Vector Database — optional for local dev) ──────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=fact-checker-claims
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Neo4j Aura (Graph Database — optional for local dev) ─────────
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
LOG_LEVEL=info
